# Copy to backend/.env for local overrides (optional).
# Production: set these in Render dashboard only — never commit real values.

SECRET_KEY=django-insecure-dev-only-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=

# Comma-separated origins (no trailing slash)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Leave empty for local filesystem media; set all three for Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
